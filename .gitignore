node_modules/
.test-data/
.playwright-mcp/
coverage/
# Test/debug screenshots — only block at repo root (where Playwright/Hymie default-saves).
# Legitimate PNGs in public/, docs/, etc. are NOT filtered.
/*.png
# Transient test artifacts (#323): per-run results stay local, not in main.
# Historical archives live under /mnt/storage/dev_artifacts/workbench/r1/tests-archive/
# (moved out of the repo per `1fbe827`).
tests/coverage-results-*.txt
tests/runbook-results-*.md
tests/gate-c-*results*.md
tests/live-results-*.txt
tests/phase*-results.md
tests/phase*-prod*-results.md
# Per-run browser screenshots written by tests/browser/*.spec.js — transient.
# (Trailing /* not / so git can traverse into the directory and honour the negation below.)
tests/browser/screenshots/*
# Verification-evidence subdirectories ARE durable per STD-003 §12.6 — keep these.
!tests/browser/screenshots/phase1-reverify/
!tests/browser/screenshots/post-gate-parity/
# Per-run @playwright/test results dir — transient.
test-results/
# Session-scoped writing artifacts — never commit.
3cli-sessions/
CLAUDE_PENANCE.txt
alignment-findings.txt
compaction-injection-discussion.md
compaction-process-checker-v2.md
docker-compose.override.yml

