{
  "_doc": "Workbench defaults. Per-key purpose comments live in the matching code module that calls config.get(...). #344 [C2] externalised 26 previously-orphan keys read with code-side fallbacks only — operators tuning behaviour without code edits go here first.",

  "session": {
    "nudgeThresholdPercent": 75,
    "resumeTailLines": 60,
    "nameMaxLength": 60,
    "promptInjectionDelayMs": 2000,
    "promptMaxLength": 4096,
    "summaryModel": "haiku",
    "summaryMaxTranscriptChars": 40000,
    "summaryMaxMessageChars": 1500
  },

  "polling": {
    "tokenUsageIntervalMs": 15000
  },

  "keepalive": {
    "refreshPercentLow": 65,
    "refreshPercentHigh": 85,
    "fallbackIntervalMin": 30,
    "refreshThreshold": 0.85,
    "checkRangeLow": 0.65,
    "checkRangeHigh": 0.85,
    "fallbackIntervalMs": 1800000,
    "queryTimeoutMs": 30000,
    "authBrokenThreshold": 3,
    "credsWatchIntervalMs": 60000
  },

  "tmux": {
    "maxSessions": 10,
    "idleWithTabDays": 99999,
    "idleWithoutTabDays": 4,
    "scanIntervalSeconds": 60,
    "windowWidth": 200,
    "windowHeight": 50
  },

  "debug": {
    "tabSwitching": false
  },

  "kb": {
    "debounceMs": 8000,
    "pullIntervalMs": 300000,
    "commitAuthorName": "Workbench Bot",
    "commitAuthorEmail": "workbench-bot@local"
  },

  "claude": {
    "defaultTimeoutMs": 120000
  },

  "ws": {
    "bufferHighWaterMark": 1048576,
    "bufferLowWaterMark": 262144,
    "pingIntervalMs": 30000,
    "scrollbackReplayLines": 5000
  },

  "resolver": {
    "maxAttempts": 30,
    "sleepMs": 2000
  },

  "qdrant": {
    "url": "http://localhost:6333",
    "debounceMs": 10000,
    "chunkWindow": 3,
    "chunkOverlap": 1,
    "ignorePatternsDefault": [
      "node_modules/**",
      ".git/**",
      "*.lock",
      "*.min.js",
      "dist/**",
      "build/**"
    ]
  },

  "routes": {
    "nonClaudeCacheTtlMs": 10000,
    "nonClaudeMatchWindowMs": 60000
  },

  "mcp": {
    "fileFindTimeoutMs": 10000,
    "fileFindMaxBuffer": 16777216
  },

  "embeddings": {
    "providers": {
      "huggingface": {
        "url": "https://router.huggingface.co/hf-inference/models/sentence-transformers/all-MiniLM-L6-v2/pipeline/feature-extraction",
        "model": "hf-free"
      },
      "gemini": {
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-embedding-001"
      },
      "openai": {
        "url": "https://api.openai.com/v1",
        "model": "text-embedding-3-small"
      }
    }
  }
}
